{
    "name": "nsfw-extension",
    "version": "1.0.0",
    "description": "Chrome Extension for real-time NSFW detection using TensorFlow.js",
    "private": true,
    "scripts": {
        "test": "jest --coverage",
        "test:watch": "jest --watchAll"
    },
    "dependencies": {
        "@tensorflow/tfjs": "^4.17.0",
        "@tensorflow/tfjs-backend-cpu": "^4.22.0",
        "@tensorflow/tfjs-core": "^4.22.0",
        "nsfwjs": "^4.2.0"
    },
    "devDependencies": {
        "@babel/core": "^7.23.0",
        "@babel/preset-env": "^7.23.0",
        "babel-jest": "^29.7.0",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0"
    },
    "jest": {
        "testEnvironment": "jsdom",
        "transform": {
            "^.+\\.js$": "babel-jest"
        },
        "setupFiles": [
            "./tests/setup.js"
        ],
        "collectCoverageFrom": [
            "ml/**/*.js",
            "content/**/*.js"
        ]
    }
}